# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///./insurance.db
# PostgreSQL (프로덕션): DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/insurance

# 금감원 API (https://finlife.fss.or.kr 에서 발급)
FSS_API_KEY=your_fss_api_key

# 네이버 API (https://developers.naver.com 에서 발급)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Claude API (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=your_anthropic_api_key

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# 비용 관리
MONTHLY_BUDGET_KRW=100000
